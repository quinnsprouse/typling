{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && cp .output/client/_shell.html .output/client/index.html",
  "outputDirectory": ".output/client",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/(.*)", "destination": "/_shell.html" }
  ]
}
